{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/scrape-lcs",
      "schedule": "0 2 * * 1,4"
    },
    {
      "path": "/api/cron/scrape-opportunities",
      "schedule": "0 3 * * 2,5"
    },
    {
      "path": "/api/cron/scrape-jobs",
      "schedule": "0 4 * * 3,6"
    },
    {
      "path": "/api/cron/deadline-reminders",
      "schedule": "0 8 * * 1,4"
    },
    {
      "path": "/api/cron/aggregate-profiles",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    }
  ]
}
