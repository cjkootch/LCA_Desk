{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/scrape-lcs",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/cron/scrape-opportunities",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/deadline-reminders",
      "schedule": "0 8 * * 1,4"
    },
    {
      "path": "/api/cron/aggregate-profiles",
      "schedule": "0 5 * * 0"
    }
  ]
}
